---
import '../styles/global.css';
import { site, nav } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = site.description } = Astro.props;
const pageTitle = title ? `${title} — ${site.title}` : site.title;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <p class="site-title-wrap">
          <a href="/" class="site-title" aria-label="home">{site.handle}</a>
        </p>
        <p class="site-header__tagline">// the personal website of {site.handle}</p>
        <nav class="nav" aria-label="primary">
          {nav.map((item) => {
            const target = item.href.replace(/\/$/, '') || '/';
            const isCurrent = target === currentPath;
            return (
              <a href={item.href} aria-current={isCurrent ? 'page' : undefined}>
                <span class="nav-bracket" aria-hidden="true">[</span>{item.label}<span class="nav-bracket" aria-hidden="true">]</span>
              </a>
            );
          })}
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <span>© {new Date().getFullYear()} {site.handle}</span>
        <a href="/contact" class="site-footer__contact">→ contact</a>
      </footer>
    </div>
  </body>
</html>
